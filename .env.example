# ============================================================================
#  TorBox Media Server — Example environment file
#  Generated automatically by setup.sh as `.env` inside the install directory.
#  The values below are illustrative ONLY — do NOT commit your real .env.
# ============================================================================

# Host user / group that will own files inside containers (`id -u` / `id -g`)
PUID=1000
PGID=1000

# IANA timezone (e.g. America/New_York, Europe/London, UTC)
TZ=UTC

# === TorBox =================================================================
# Get yours from https://torbox.app/settings
TORBOX_API_KEY=replace-with-your-torbox-api-key

# === Paths (absolute) =======================================================
# Generated configs and persistent data — created and owned by PUID:PGID.
CONFIG_DIR=/absolute/path/to/torbox-media-server/configs
DATA_DIR=/absolute/path/to/torbox-media-server/data
# rclone FUSE mount point. MUST NOT be inside CONFIG_DIR or the install dir.
MOUNT_DIR=/mnt/torbox-media

# === Media server selection =================================================
# Selects which media-server profile docker compose activates.
# One of: plex, jellyfin
COMPOSE_PROFILES=plex

# Plex claim token from https://www.plex.tv/claim/ — single-use, 4-minute TTL.
# setup.sh removes this entry from .env after the first successful claim.
PLEX_CLAIM=

# === *arr API keys (auto-seeded, 32-char lowercase hex) =====================
RADARR_API_KEY=00000000000000000000000000000000
SONARR_API_KEY=00000000000000000000000000000000
PROWLARR_API_KEY=00000000000000000000000000000000

# === Decypharr web UI credentials (auto-seeded) =============================
DECYPHARR_USER=torbox
DECYPHARR_PASS=replace-with-generated-password

# === *arr admin credentials (auto-seeded, independent per service) ==========
RADARR_ADMIN_USER=admin
RADARR_ADMIN_PASS=replace-with-generated-password
SONARR_ADMIN_USER=admin
SONARR_ADMIN_PASS=replace-with-generated-password
PROWLARR_ADMIN_USER=admin
PROWLARR_ADMIN_PASS=replace-with-generated-password
